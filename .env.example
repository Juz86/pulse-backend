# ─── Firebase ─────────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ─── E-mail (Nodemailer via Gmail) ────────────────────────────────────────────
EMAIL_USER=jouw@gmail.com
EMAIL_PASS=app-wachtwoord

# ─── App URLs ─────────────────────────────────────────────────────────────────
# Stel in als jouw Cloudflare Pages URL (bijv. https://pulse-xyz.pages.dev)
APP_URL=https://jouw-app.pages.dev
FRONTEND_URL=https://jouw-app.pages.dev

# ─── Redis berichtenwachtrij (optioneel) ─────────────────────────────────────
# Railway: stel in via dashboard → Add Plugin → Redis
# Waarde is beschikbaar als $REDIS_URL na toevoeging van de plugin
# Zonder deze variabele werkt de app normaal (fallback op Firestore)
REDIS_URL=redis://default:wachtwoord@host:6379
